{
  "name": "@kpi-ui/utils",
  "version": "0.0.1",
  "description": "kpi ui lib shared utils",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "kpi-ui",
    "utils"
  ],
  "author": "clearink",
  "license": "ISC",
  "scripts": {
    "compile:es": "kpi-scripts compile:code -f es -d es && tsc --declarationDir es",
    "compile:lib": "kpi-scripts compile:code -f cjs -d lib && tsc --declarationDir lib",
    "ccc": "npm run compile:es && npm run compile:lib"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.20.13",
    "react-fast-compare": "^3.2.0",
    "react-is": "^18.2.0"
  },
  "devDependencies": {
    "@kpi-ui/scripts": "workspace:^",
    "@types/react": "^18.0.27",
    "@types/react-is": "^17.0.3",
    "typescript": "^5.0.2"
  }
}
