{
  "name": "@kpi-ui/validator",
  "version": "0.0.0",
  "description": "kpi-ui form validator lib",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "form",
    "validator"
  ],
  "author": "clearink",
  "license": "ISC",
  "scripts": {
    "compile:es": "kpi-scripts compile:code -f es -d es && tsc --declarationDir es",
    "compile:lib": "kpi-scripts compile:code -f cjs -d lib && tsc --declarationDir lib",
    "ccc": "npm run compile:es && npm run compile:lib"
  },
  "dependencies": {
    "@babel/runtime": "^7.20.13",
    "@kpi-ui/utils": "workspace:^"
  },
  "devDependencies": {
    "@kpi-ui/scripts": "workspace:^",
    "typescript": "^5.0.2"
  }
}
