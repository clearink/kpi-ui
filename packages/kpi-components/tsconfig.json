{
  "extends": "../../tsconfig.json",
  "include": ["src"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "_shared/*": ["src/_shared/*"]
    },
    "noEmit": false,
    "declaration": true,
    "declarationDir": "esm",
    "emitDeclarationOnly": true
  }
}
