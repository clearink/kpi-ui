{
  "extends": "../../tsconfig.json",
  "include": ["src"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "_components": ["src/_shared/components"],
      "_components/*": ["src/_shared/components/*"],
      "_constants": ["src/_shared/constants"],
      "_constants/*": ["src/_shared/constants/*"],
      "_contexts": ["src/_shared/contexts"],
      "_contexts/*": ["src/_shared/contexts/*"],
      "_hooks": ["src/_shared/hooks"],
      "_hooks/*": ["src/_shared/hooks/*"],
      "_utils": ["src/_shared/utils"],
      "_utils/*": ["src/_shared/utils/*"]
    }
  }
}
