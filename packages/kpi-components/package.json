{
  "name": "@kpi-ui/components",
  "version": "0.0.1",
  "description": "react components",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "kpi-ui",
    "react",
    "components"
  ],
  "author": "clearink",
  "license": "ISC",
  "scripts": {
    "compile:es": "kpi-scripts compile:code -f es -d es && tsc --declarationDir es",
    "compile:lib": "kpi-scripts compile:code -f cjs -d lib && tsc --declarationDir lib",
    "ccc": "npm run compile:es && npm run compile:lib"
  },
  "dependencies": {
    "@babel/runtime": "^7.20.13",
    "@kpi-ui/internal": "workspace:^",
    "@kpi-ui/utils": "workspace:^",
    "@kpi-ui/hooks": "workspace:^",
    "classnames": "^2.3.1"
  },
  "devDependencies": {
    "@kpi-ui/scripts": "workspace:^",
    "@types/react": "^18.0.14",
    "@types/react-dom": "^18.0.10",
    "react": "^18.2.0",
    "typescript": "^5.0.2"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
