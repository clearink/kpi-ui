{
  "name": "kpi-ui",
  "version": "0.0.1",
  "description": "kpi-ui components",
  "license": "MIT",
  "sideEffects": [
    "dist/*",
    "esm/**/style/*",
    "lib/**/style/*",
    "*.scss"
  ],
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.mjs",
      "require": "./lib/index.js"
    },
    "./*": "./*"
  },
  "main": "lib/index.js",
  "module": "esm/index.mjs",
  "unpkg": "dist/index.min.js",
  "jsdelivr": "dist/index.min.js",
  "types": "esm/index.d.ts",
  "files": [
    "dist",
    "esm",
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "kpi-scripts build:ui"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.7",
    "@kpi-ui/icons": "workspace:^",
    "@kpi-ui/validator": "workspace:^",
    "classnames": "^2.5.1",
    "react-fast-compare": "^3.2.0",
    "react-is": "^18.2.0"
  },
  "devDependencies": {
    "@kpi-ui/scripts": "workspace:^",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "typescript": "^5.0.2"
  }
}
