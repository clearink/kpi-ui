{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@kpi/ui": ["src/index.tsx"],
      "@kpi/ui/es/*": ["src/*"]
    },
    "experimentalDecorators": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "allowSyntheticDefaultImports": true,
    "target": "es6",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["react", "react-dom", "node"]
  },
  "include": ["src"],
  "exclude": ["docs", "tests", "**/**/*.scss"],
  "compileOnSave": false
}
