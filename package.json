{
  "name": "kpi-ui",
  "version": "0.0.0",
  "main": "index.js",
  "private": true,
  "useWorkspaces": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "A KPI UI Design",
  "scripts": {
    "test": "lerna run test",
    "diff": "lerna diff",
    "bootstrap": "lerna bootstrap",
    "build:cli": "cd ./packages/kpi-cli & npm run build",
    "add:eslint-config": "lerna add eslint-config-kpi-ui --scope=\"@kpi/cli\"",
    "dev:ui": "cd ./packages/kpi-ui & yarn run dev",
    "create:site": "lerna create kpi-site"
  },
  "husky": {
    "hooks": {}
  },
  "license": "MIT",
  "devDependencies": {
    "lerna": "^4.0.0"
  }
}