{
  "useWorkspaces": true,
  "npmClient": "yarn",
  "packages": ["packages/*"],
  "command": {
    "publish": {
      "conventionalCommits": false,
      "message": "chore(release): publish new version. KPI++"
    }
  },
  "ignoreChanges": [
    "ignored-file", 
    "**/__tests__/**", 
    "**/*.md"
  ],
  "version": "independent"
}
